# 飞书(Feishu/Lark) API 配置
# 在飞书开放平台创建企业自建应用获取

# 应用凭证（飞书开放平台 → 应用详情 → 凭证与基础信息）
NEXT_PUBLIC_FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxx

# 多维表格 ID（从飞书多维表格 URL 中获取）
# 例如：https://feishu.cn/base/xxxxxxxxxx
NEXT_PUBLIC_FEISHU_BASE_ID=xxxxxxxxxx

# 表格 ID（飞书多维表格中右键表格 → 复制链接 → 提取 tableId）
NEXT_PUBLIC_FEISHU_TABLE_ID=tblxxxxxxxx
